{
  "name": "tanka-work-memory-cli",
  "version": "1.5.1",
  "private": true,
  "description": "tanka-wm — discover Claude Code / Codex coding-agent sessions per project and sync them to Tanka cloud storage. Distributed as a self-contained bun binary; bun is also the dev runtime.",
  "type": "module",
  "engines": {
    "bun": ">=1.3"
  },
  "scripts": {
    "dev": "bun src/cli.tsx",
    "dev:watch": "bun --watch src/cli.tsx",
    "build": "bun scripts/build-binaries.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "test": "bun test"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "ink": "^7.0.3",
    "react": "^19.2.6",
    "react-devtools-core": "^6.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "^1.3.14",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.0",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.5.0"
  }
}