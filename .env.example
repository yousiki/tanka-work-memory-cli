# Tanka API base URLs — one per environment.
# Copy this file to .env and fill in the actual URLs.
# These are read at runtime during development, and inlined at compile time
# via `--define` during CI builds (see scripts/build-binaries.mjs).
TANKA_API_URL_DEV=
TANKA_API_URL_TEST=
TANKA_API_URL_UAT=
TANKA_API_URL_PROD=
